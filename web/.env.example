DATABASE_URL=

# Public origin of this app (no trailing slash). Used to build the SSO redirect URL
# https://…/auth/callback when ALDER_SSO_REDIRECT_URI is not set.
# Local: http://localhost:3000  Production: https://sizzle.alder.so
SIZZLE_APP_URL=

# Alder central SSO (see also SIZZLE_APP_URL above)
ALDER_SSO_BASE_URL=https://alder.so
# Optional if SIZZLE_APP_URL is set; must match an allowed redirect URI in Alder.
# ALDER_SSO_REDIRECT_URI=https://sizzle.alder.so/auth/callback
ALDER_SSO_SOURCE=sizzle
ALDER_SSO_SIGNING_SECRET=
ALDER_SSO_EXCHANGE_SECRET=
